{
  "name": "react-calendar-datetime",
  "version": "2.1.0",
  "description": "React date and time calendar component (with presets and locale)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/react-calendar-datetime"
  },
  "homepage": "https://github.com/kirilinsky/react-calendar-datetime/",
  "bugs": {
    "url": "https://github.com/kirilinsky/react-calendar-datetime/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ladle serve",
    "dev": "tsup --watch",
    "build": "tsup",
    "build:demo": "ladle build",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/esbuild-plugin": "^2.3.21",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "calendar",
    "datepicker",
    "datetime-picker",
    "time-picker",
    "react-calendar",
    "react-datepicker",
    "dayjs",
    "localization",
    "multi-language",
    "themes",
    "customizable",
    "presets",
    "lightweight",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT",
  "dependencies": {
    "@vanilla-extract/css": "^1.18.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20"
  }
}
