{
  "name": "react-calendar-datetime",
  "version": "2.0.1",
  "description": "React date and time calendar component (with presets and locale)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirilinsky/react-calendar-datetime"
  },
  "homepage": "https://github.com/kirilinsky/react-calendar-datetime/",
  "bugs": {
    "url": "https://github.com/kirilinsky/react-calendar-datetime/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "ladle serve",
    "dev": "tsup --watch",
    "build": "tsup",
    "build:demo": "ladle build",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react datepicker",
    "calendar date time",
    "react calendar date time",
    "datetime picker",
    "calendar locale react datetimepicker"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Kirilinsky (https://github.com/kirilinsky)",
  "license": "MIT",
  "dependencies": {
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20"
  }
}